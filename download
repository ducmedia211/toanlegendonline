import React, { useEffect, useState } from 'react';
import { motion, AnimatePresence } from 'motion/react';
import { Trophy, Medal, Star, Clock, ArrowLeft, RefreshCw, User as UserIcon } from 'lucide-react';
import { LeaderboardEntry, Grade } from '../types';
import { fetchLeaderboard } from '../lib/leaderboard';

interface LeaderboardScreenProps {
  onBack: () => void;
  currentUserId: string;
}

export const LeaderboardScreen: React.FC<LeaderboardScreenProps> = ({ onBack, currentUserId }) => {
  const [entries, setEntries] = useState<LeaderboardEntry[]>([]);
  const [isLoading, setIsLoading] = useState(true);
  const [isRefreshing, setIsRefreshing] = useState(false);
  const [selectedGrade, setSelectedGrade] = useState<Grade | null>(null);

  const loadData = async (silent = false) => {
    if (!silent) setIsLoading(true);
    if (!silent) setIsRefreshing(true);
    try {
      const data = await fetchLeaderboard(selectedGrade || undefined);
      setEntries(data);
    } finally {
      setIsLoading(false);
      setIsRefreshing(false);
    }
  };

  useEffect(() => {
    loadData();
    // Auto refresh every 15 seconds to simulate real-time feel
    const interval = setInterval(() => loadData(true), 15000);
    return () => clearInterval(interval);
  }, [selectedGrade]);

  const formatVNTime = (timestamp: number) => {
    const diff = Date.now() - timestamp;
    const seconds = Math.floor(diff / 1000);
    
    if (seconds < 30) return 'Vừa xong';
    if (seconds < 60) return `${seconds} giây trước`;
    
    const minutes = Math.floor(seconds / 60);
    if (minutes < 60) return `${minutes} phút trước`;
    
    const hours = Math.floor(minutes / 60);
    if (hours < 24) return `${hours} giờ trước`;
    
    // Day format for Vietnam
    return new Intl.DateTimeFormat('vi-VN', {
      timeZone: 'Asia/Ho_Chi_Minh',
      day: '2-digit',
      month: '2-digit',
      year: 'numeric',
      hour: '2-digit',
      minute: '2-digit',
      second: '2-digit'
    }).format(new Date(timestamp));
  };

  return (
    <div className="flex flex-col items-center p-4 md:p-10 min-h-[85vh] font-sans">
      <motion.div 
        initial={{ opacity: 0, y: 30 }}
        animate={{ opacity: 1, y: 0 }}
        className="w-full max-w-2xl anime-card p-6 md:p-12 relative bg-[#151921] border-white/5"
      >
        <div className="flex justify-between items-center mb-10">
          <button 
            onClick={onBack}
            className="flex items-center space-x-2 text-slate-400 hover:text-white transition-colors"
          >
            <ArrowLeft className="w-5 h-5" />
            <span className="font-bold">Quay lại</span>
          </button>
          
          <div className="flex items-center space-x-2">
             <Trophy className="w-8 h-8 text-anime-yellow" />
             <h2 className="text-3xl font-display font-black text-white">BẢNG XẾP HẠNG</h2>
          </div>

          <button 
            onClick={loadData}
            disabled={isRefreshing}
            className={`p-2 rounded-xl bg-white/5 hover:bg-white/10 transition-all ${isRefreshing ? 'animate-spin' : ''}`}
          >
            <RefreshCw className="w-5 h-5 text-anime-blue" />
          </button>
        </div>

        {/* Info Banner */}
        <div className="bg-anime-blue/10 border border-anime-blue/20 rounded-2xl p-4 mb-4 text-center">
            <p className="text-sm font-bold text-anime-blue">TOP 10 Huyền Thoại Toán Học ⚔️</p>
            <p className="text-[10px] text-slate-500 uppercase tracking-widest mt-1">Dữ liệu được cập nhật theo thời gian thực</p>
        </div>

        {/* Grade Tabs */}
        <div className="flex flex-wrap justify-center gap-2 mb-8">
            <button 
                onClick={() => setSelectedGrade(null)}
                className={`px-4 py-2 rounded-xl text-xs font-bold transition-all border-2 ${selectedGrade === null ? 'bg-anime-blue border-anime-blue text-white shadow-lg' : 'bg-white/5 border-white/5 text-slate-400 hover:bg-white/10'}`}
            >
                TẤT CẢ
            </button>
            {[6, 7, 8, 9].map((g) => (
                <button 
                    key={g}
                    onClick={() => setSelectedGrade(g as Grade)}
                    className={`px-4 py-2 rounded-xl text-xs font-bold transition-all border-2 ${selectedGrade === g ? 'bg-anime-blue border-anime-blue text-white shadow-lg' : 'bg-white/5 border-white/5 text-slate-400 hover:bg-white/10'}`}
                >
                    KHỐI {g}
                </button>
            ))}
        </div>

        <div className="space-y-4">
          {isLoading ? (
            <div className="flex flex-col items-center justify-center py-20 space-y-4">
               <div className="w-12 h-12 border-4 border-anime-blue border-t-transparent rounded-full animate-spin" />
               <p className="text-slate-500 font-bold">Đang tải cao thủ...</p>
            </div>
          ) : entries.length === 0 ? (
            <div className="text-center py-20">
               <p className="text-slate-500 font-bold">Chưa có ai tham gia bảng xếp hạng cả. Hãy là người đầu tiên!</p>
            </div>
          ) : (
            <AnimatePresence>
              {entries.map((entry, index) => {
                const isCurrentUser = entry.id === currentUserId;
                const isTop3 = index < 3;
                
                return (
                  <motion.div
                    key={entry.id}
                    initial={{ opacity: 0, x: -20 }}
                    animate={{ opacity: 1, x: 0 }}
                    transition={{ delay: index * 0.05 }}
                    className={`
                      relative group flex items-center p-4 md:p-5 rounded-2xl border-2 transition-all
                      ${isCurrentUser ? 'bg-anime-blue/20 border-anime-blue' : 'bg-white/5 border-white/5 hover:bg-white/10'}
                    `}
                  >
                    {/* Rank Badge */}
                    <div className={`
                      w-10 h-10 md:w-12 md:h-12 flex items-center justify-center rounded-xl md:rounded-2xl shrink-0 font-display font-black text-lg md:text-xl
                      ${index === 0 ? 'bg-anime-yellow text-amber-900 shadow-[0_0_15px_rgba(255,215,0,0.3)]' : 
                        index === 1 ? 'bg-slate-300 text-slate-800' : 
                        index === 2 ? 'bg-amber-600 text-amber-100' : 
                        'bg-white/10 text-slate-400'}
                    `}>
                      {index + 1}
                    </div>

                    <div className="ml-4 flex-1 min-w-0">
                      <div className="flex items-center space-x-2">
                        <span className={`font-bold truncate text-base md:text-lg ${isCurrentUser ? 'text-white' : 'text-slate-200'}`}>
                          {entry.name}
                        </span>
                        {isCurrentUser && (
                          <span className="bg-anime-blue text-white text-[8px] font-black px-1.5 py-0.5 rounded uppercase">Bạn</span>
                        )}
                        {isTop3 && (
                          <Medal className={`w-4 h-4 ${index === 0 ? 'text-anime-yellow' : index === 1 ? 'text-slate-400' : 'text-amber-600'}`} />
                        )}
                      </div>
                      <div className="flex items-center space-x-4 mt-1">
                        <span className="text-xs text-slate-500 font-medium">Lớp {entry.grade}</span>
                        <div className="w-1 h-1 bg-slate-700 rounded-full" />
                        <span className="text-xs text-slate-600 flex items-center">
                          <Clock className="w-3 h-3 mr-1" />
                          {formatVNTime(entry.timestamp)}
                        </span>
                      </div>
                    </div>

                    <div className="text-right ml-4">
                      <div className="text-xl md:text-2xl font-display font-black text-anime-mint">
                        {entry.points.toLocaleString()}
                      </div>
                      <div className="text-[10px] text-slate-500 font-bold uppercase tracking-wider">XP</div>
                    </div>

                    {index === 0 && (
                      <motion.div 
                        initial={{ opacity: 0, scale: 0 }}
                        animate={{ opacity: 1, scale: 1 }}
                        className="absolute -top-3 -right-3"
                      >
                        <div className="bg-anime-yellow p-1.5 rounded-full shadow-lg">
                           <Star className="w-4 h-4 text-amber-900 fill-amber-900" />
                        </div>
                      </motion.div>
                    )}
                  </motion.div>
                );
              })}
            </AnimatePresence>
          )}
        </div>
        
        <div className="mt-10 pt-6 border-t border-white/5 text-center">
           <p className="text-xs text-slate-600 italic">
             Tiếp tục học để leo lên ngôi vị quán quân nào! 🏆
           </p>
        </div>
      </motion.div>
    </div>
  );
};
